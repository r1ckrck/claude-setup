{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Bash(git --version:*)",
            "Bash(git config:*)",
            "Bash(git status:*)",
            "Bash(git log:*)",
            "Bash(git diff:*)",
            "Bash(git show:*)",
            "Bash(git remote -v:*)",
            "Bash(ls:*)",
            "Bash(cat:*)",
            "Bash(head:*)",
            "Bash(tail:*)",
            "Bash(find:*)",
            "Bash(grep:*)",
            "Bash(wc:*)",
            "Bash(pnpm ls:*)",
            "Bash(pnpm list:*)",
            "Bash(pnpm install:*)",
            "Bash(pnpm add:*)",
            "Bash(pnpm update:*)",
            "Bash(pnpm build:*)",
            "Bash(pnpm dev:*)",
            "Bash(pnpm run:*)",
            "Bash(turbo run:*)",
            "Bash(turbo build:*)",
            "Bash(turbo dev:*)",
            "Bash(pnpm --filter platform exec playwright test:*)",
            "Bash(pnpm test:*)",
            "Bash(npx playwright:*)",
            "Bash(playwright-cli:*)",
            "Bash(npx tsc:*)",
            "Bash(pnpm tsc:*)",
            "Bash(npx eslint:*)",
            "Bash(pnpm eslint:*)",
            "Bash(npx prettier:*)",
            "Bash(pnpm prettier:*)",
            "Bash(pnpm next:*)",
            "Bash(npx next:*)",
            "Bash(curl:*)",
            "Bash(ffmpeg:*)",
            "Bash(ffprobe:*)",
            "Bash(convert:*)",
            "Bash(magick:*)",
            "Bash(pandoc:*)",
            "Bash(pdflatex:*)",
            "Bash(xelatex:*)",
            "Bash(latexmk:*)",
            "Bash(inkscape:*)",
            "Bash(svgo:*)",
            "Bash(npm run:*)",
            "Bash(npx:*)",
            "Bash(node:*)",
            "Bash(python3:*)",
            "WebFetch(domain:localhost)",
            "mcp__figma__use_figma",
            "mcp__figma__get_metadata",
            "mcp__figma__get_design_context",
            "mcp__figma__get_screenshot",
            "mcp__figma__get_variable_defs",
            "mcp__paper__create_artboard",
            "mcp__paper__delete_nodes",
            "mcp__paper__duplicate_nodes",
            "mcp__paper__finish_working_on_nodes",
            "mcp__paper__get_basic_info",
            "mcp__paper__get_children",
            "mcp__paper__get_computed_styles",
            "mcp__paper__get_fill_image",
            "mcp__paper__get_font_family_info",
            "mcp__paper__get_guide",
            "mcp__paper__get_jsx",
            "mcp__paper__get_node_info",
            "mcp__paper__get_screenshot",
            "mcp__paper__get_tree_summary",
            "mcp__paper__rename_nodes",
            "mcp__paper__set_text_content",
            "mcp__paper__update_styles",
            "mcp__paper__write_html",
            "mcp__plugin_context7_context7__resolve-library-id",
            "mcp__plugin_context7_context7__query-docs",
            "WebSearch"
        ],
        "defaultMode": "default"
    },
    "effortLevel": "medium",
    "voiceEnabled": true,
    "showClearContextOnPlanAccept": true,
    "mcpServers": {
        "paper": {
            "type": "http",
            "url": "http://127.0.0.1:29979/mcp"
        },
        "figma": {
            "type": "http",
            "url": "https://mcp.figma.com/mcp"
        }
    }
}